{
  "title": "Open a terminal window with Option-T",
  "rules": [
    {
        "description": "Open a terminal window with Option-T",
        "manipulators": [
            {
                "from": {
                    "key_code": "t",
                    "modifiers": {
                        "mandatory": [
                            "left_option"
                        ],
                        "optional": [
                        ]
                    }
                },
                "to": [
                    {
                        "shell_command": "open -a Terminal ~"
                    }
                ],
                "type": "basic"
            },
            {
                "from": {
                    "key_code": "t",
                    "modifiers": {
                        "mandatory": [
                            "right_option"
                        ],
                        "optional": [
                        ]
                    }
                },
                "to": [
                    {
                        "shell_command": "open -a Terminal ~"
                    }
                ],
                "type": "basic"
            }
        ]
    }
  ]
}

